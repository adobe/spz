{
  "name": "@adobe/spz",
  "version": "0.2.0",
  "description": "WebAssembly module for loading Gaussian splat (SPZ) files",
  "main": "dist/spz.js",
  "types": "dist/spz.d.ts",
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "publishPackage": "npm publish --access public",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/spz.d.ts",
      "default": "./dist/spz.js"
    }
  },
  "keywords": [
    "wasm",
    "emscripten",
    "gaussian-splatting",
    "3d"
  ],
  "author": "Niantic Labs & Adobe",
  "license": "ISC",
  "homepage": "https://github.com/nianticlabs/spz",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
